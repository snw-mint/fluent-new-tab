{
  "manifest_version": 3,
  "name": "Fluent New Tab",
  "version": "4.1",
  "description": "A minimalist, customizable New Tab page inspired by Fluent Design.",
  "default_locale": "en_US",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "action": {
    "default_icon": "assets/icon-48.png"
  },
  "background": {
    "service_worker": "scripts/background.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' data: blob: https:;"
  },
  "permissions": ["storage", "unlimitedStorage", "search", "alarms"],
  "optional_host_permissions": [
    "https://duckduckgo.com/*",
    "https://peapix.com/*",
    "https://img.peapix.com/*",
    "https://api.nasa.gov/*",
    "https://apod.nasa.gov/*",
    "https://commons.wikimedia.org/*",
    "https://upload.wikimedia.org/*",
    "https://geocoding-api.open-meteo.com/*",
    "https://api.open-meteo.com/*",
    "https://air-quality-api.open-meteo.com/*",
    "https://www.google.com/*",
    "https://lens.google.com/*"
  ]
}
